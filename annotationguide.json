{
    "abcPlusVersion": "1.4.0",
    "directives": {
        "dir": {
            "scope": "direction",
            "placement": "before_measure",
            "attributes": {
                "mood": "string",
                "intensity": "float"
            },
            "musicXML": {
                "element": "direction",
                "type": "words"
            }
        },
        "fx": {
            "scope": "measure",
            "placement": "after_barline",
            "attributes": {
                "name": "string",
                "speed": "string"
            },
            "musicXML": {
                "element": "direction",
                "type": "effect"
            }
        },
        "analysis": {
            "scope": "measure",
            "placement": "after_barline",
            "attributes": {
                "function": "string"
            },
            "musicXML": {
                "element": "harmony",
                "type": "function"
            }
        },
        "game_state": {
            "scope": "measure",
            "placement": "after_barline",
            "attributes": {
                "state": "string"
            },
            "musicXML": {
                "element": "direction",
                "type": "words",
                "subtype": "game-state"
            }
        },
        "loop": {
            "scope": "measure",
            "placement": "after_barline",
            "attributes": {
                "safe": "boolean"
            },
            "musicXML": {
                "element": "repeat"
            }
        },
        "art": {
            "scope": "note",
            "placement": "after_note",
            "attributes": {
                "type": "string"
            },
            "musicXML": {
                "element": "notations",
                "type": "articulations"
            }
        },
        "marker": {
            "scope": "measure",
            "placement": "before_measure",
            "attributes": {
                "text": "string"
            },
            "musicXML": {
                "element": "direction",
                "type": "rehearsal"
            }
        },
        "measurenumbering": {
            "scope": "score",
            "placement": "global",
            "attributes": {
                "value": "string"
            },
            "musicXML": {
                "element": "print",
                "type": "measure-numbering"
            }
        },
        "vskip": {
            "scope": "score",
            "placement": "global",
            "attributes": {
                "value": "number"
            },
            "musicXML": {
                "element": "system-distance"
            }
        },
        "sep": {
            "scope": "score",
            "placement": "global",
            "attributes": {},
            "musicXML": {
                "element": "system-dividers"
            }
        },
        "newpage": {
            "scope": "score",
            "placement": "global",
            "attributes": {},
            "musicXML": {
                "element": "print",
                "type": "new-page"
            }
        },
        "newline": {
            "scope": "score",
            "placement": "global",
            "attributes": {},
            "musicXML": {
                "element": "print",
                "type": "new-system"
            }
        },
        "swing": {
            "scope": "measure",
            "placement": "before_measure",
            "attributes": {},
            "musicXML": {
                "element": "sound",
                "type": "swing",
                "value": "yes"
            }
        },
        "swing-off": {
            "scope": "measure",
            "placement": "before_measure",
            "attributes": {},
            "musicXML": {
                "element": "sound",
                "type": "swing",
                "value": "no"
            }
        },
        "mute": {
            "scope": "measure",
            "placement": "before_measure",
            "attributes": {},
            "musicXML": {
                "element": "sound",
                "type": "mute",
                "value": "yes"
            }
        },
        "mute-off": {
            "scope": "measure",
            "placement": "before_measure",
            "attributes": {},
            "musicXML": {
                "element": "sound",
                "type": "mute",
                "value": "no"
            }
        },
        "frame": {
            "scope": "measure",
            "placement": "after_barline",
            "attributes": {
                "name": "string",
                "fret": "number",
                "pattern": "string"
            },
            "musicXML": {
                "element": "harmony",
                "type": "frame"
            }
        },
        "fb": {
            "scope": "measure",
            "placement": "after_barline",
            "attributes": {
                "figures": "string"
            },
            "musicXML": {
                "element": "figured-bass"
            }
        }
    }
}